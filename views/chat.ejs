<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../styles/general.css">
    <link rel="stylesheet" href="../styles/chat.css">
    <link rel="stylesheet" href="../styles/authentication.css">
    <title><%= title %>></title>
</head>
<body>
<header>
    <div id="title-block">
        <h1><%= title%></h1>
        <hr>
    </div>
    <div id="navigation-block">
        <nav>
            <ul class = "nav-links">
                <li><a id="to-main-page">Главная</a></li>
            </ul>
        </nav>
    </div>
</header>
<main>
    <div id="content-block">
        <div id="authorisation-block">
            <div id="auth-btns-block">
                <h2>Авторизация</h2>
                <div id="auth-btns">
                    <button id="log-in-btn" class="btn">Войти</button>
                    <button id="registration-btn" class="btn">Регистрация</button>
                </div>
            </div>
            <div id="log-in-block">
                <form>
                    <h3>Войти</h3>
                    <div class="username-block">
                        <label>Имя пользователя</label>
                        <input type="text" id="username-input">
                    </div>
                    <div class="password-block">
                        <label>Пароль</label>
                        <input type="password" id="password-input">
                    </div>
                    <div>
                        <button type="submit" class="btn" id="submit-login-btn">Подтвердить</button>
                        <button type="button" class="cancel-btn btn">Отмена</button>
                    </div>
                </form>
            </div>
            <div id="registration-block">
                <form>
                    <h3>Регистрация</h3>
                    <div class="username-block">
                        <label>Имя пользователя</label>
                        <input type="text" id="username-input">
                    </div>
                    <div class="password-block">
                        <label>Пароль</label>
                        <input type="password" id="password-input">
                        <label>Повторите пароль</label>
                        <input type="password" id="password-input-submit">
                    </div>
                    <div>
                        <button type="submit" class="btn" id="submit-reg-btn">Подтвердить</button>
                        <button type="button" class="cancel-btn btn">Отмена</button>
                    </div>
                </form>
            </div>
        </div>
        <div id="chat-block">
            <div id="sidebar-block">
                <div id ="current-user-block">
                    <h5 id="current-name"></h5>
                </div>
                <div id="user-list">

                </div>
            </div>
            <div id="main-chat-block">
                <div id="chat-header">
                    <h5 id="companion-name"></h5>
                </div>
                <div id="chat"></div>
                <div class="message-input-block">
                    <div class="input-group">
                        <input type="text" id="message-input" placeholder="Введите сообщение или перетащите файл...">
                        <button type="button" id="attach-btn" class="btn">Выбрать файл</button>
                        <button type="button" id="send-btn" class="btn">Отправить</button>
                    </div>
                    <input type="file" id="file-input" multiple accept="image/*,.pdf,.doc,.docx,.txt,.jpg,.png,.gif,.jpeg">
                </div>
            </div>
        </div>
    </div>
</main>
<script src="/socket.io/socket.io.js"></script>
<script type = "module" src="/js/chat.js"></script>
<script type = "module" src="/js/authentication.js"></script>
</body>
</html>